# backend/.env.example
# Copy this file to backend/.env and fill in your own values.
# Do NOT put real credentials here — this file is committed to git.

# MySQL Database
DB_HOST=your-db-host
DB_PORT=4000
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=ecommerce
DB_SSL=true

# JWT Secret (use a long random string)
JWT_SECRET=your-jwt-secret

# Express Server
PORT=5000
FRONTEND_URL=http://127.0.0.1:5500

# Optional
NODE_ENV=development

# ==================== Rate Limiter Configuration ====================
# Window for all rate limiters (milliseconds)
RATE_LIMIT_WINDOW_MS=900000
# Login attempts per window
RATE_LIMIT_LOGIN_MAX=5
# Signup attempts per window
RATE_LIMIT_SIGNUP_MAX=5
# Refresh token requests per window
RATE_LIMIT_REFRESH_MAX=10
# Forgot password attempts per window
RATE_LIMIT_FORGOT_PASSWORD_MAX=3
# OTP verification attempts per window
RATE_LIMIT_OTP_VERIFY_MAX=3
# Reset password attempts per window
RATE_LIMIT_RESET_PASSWORD_MAX=3
# OTP request attempts per window
RATE_LIMIT_OTP_REQUEST_MAX=3
# OTP specific window (5 minutes)
RATE_LIMIT_OTP_WINDOW_MS=300000